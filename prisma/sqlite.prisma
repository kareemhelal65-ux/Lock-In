generator client {
  provider = "prisma-client-js"
  output   = "./generated/sqlite-client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                   String   @id
  email                String   @unique
  username             String   @unique
  passwordHash         String
  name                 String
  hypeScore            Int      @default(0)
}

model Vendor {
  id                   String   @id
  username             String   @unique
  name                 String
}
