generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String             @id @default(uuid())
  email                String             @unique
  username             String             @unique
  passwordHash         String
  name                 String
  avatar               String
  hypeScore            Int                @default(0)
  sawaCurrency         Int                @default(0)
  keysAvailable        Int                @default(0)
  activeCardId         String?
  walletBalance        Float              @default(0.0)
  locksUntilMysteryCop Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  streaksAsFriend      FriendshipStreak[] @relation("FriendStreak")
  streaksAsUser        FriendshipStreak[] @relation("UserStreak")
  hypeLogs             HypeLog[]
  hostedOrders         Order[]            @relation("HostRelation")
  participantOrders    ParticipantOrder[]
  inventory            UserCard[]
  deliveryRequests     DeliveryRequest[]  @relation("DeliveryRequests")
  acceptedDeliveries   DeliveryRequest[]  @relation("AcceptedDeliveries")
}

model HypeLog {
  id        String   @id @default(uuid())
  userId    String
  points    Int
  reason    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Card {
  id          String     @id @default(uuid())
  name        String     @unique
  description String
  perkCode    String     @unique
  rarity      String
  dropRate    Float      @default(0.1)
  usage       String     @default("ONE_TIME")
  users       UserCard[]
}

model UserCard {
  id         String   @id @default(uuid())
  userId     String
  cardId     String
  isUsed         Boolean  @default(false)
  remainingValue Float?
  acquiredAt     DateTime @default(now())
  card       Card     @relation(fields: [cardId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model FriendshipStreak {
  id        String   @id @default(uuid())
  userId    String
  friendId  String
  streak    Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  friend    User     @relation("FriendStreak", fields: [friendId], references: [id])
  user      User     @relation("UserStreak", fields: [userId], references: [id])

  @@unique([userId, friendId])
}

model Vendor {
  id                    String      @id @default(uuid())
  username              String      @unique
  passwordHash          String
  name                  String
  image                 String
  bannerImage           String?
  rating                Float       @default(0.0)
  ratingCount           Int         @default(0)
  status                String      @default("LIVE")
  announcementBanner    String?
  instapayAddress       String?
  instapayName          String?
  commissionOwedBalance Float       @default(0.0)
  lifetimeSales         Float       @default(0.0)
  lifetimeOrders        Int         @default(0)
  ledgerPinHash         String?
  hypeMultiplier        Float       @default(1.0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  announcementUpdatedAt DateTime?
  flashDrops            FlashDrop[]
  menuItems             MenuItem[]
  orders                Order[]
}

model MenuItem {
  id                String      @id @default(uuid())
  vendorId          String
  name              String
  description       String
  price             Float
  image             String
  inStock           Boolean     @default(true)
  requiredHypeLevel Int         @default(0)
  category          String
  addOns            String      @default("[]")
  vendor            Vendor      @relation(fields: [vendorId], references: [id])
  orderItems        OrderItem[]
}

model FlashDrop {
  id            String      @id @default(uuid())
  vendorId      String
  itemName      String
  originalPrice Float
  dropPrice     Float
  totalQuantity Int
  quantityLeft  Int
  expiresAt     DateTime
  isActive      Boolean     @default(true)
  vendor        Vendor      @relation(fields: [vendorId], references: [id])
  orderItems    OrderItem[]
}

model Order {
  id              String             @id @default(uuid())
  orderNumber     String
  hostId          String
  vendorId        String
  totalAmount     Float
  sawaSubsidy     Float              @default(0.0)
  isCoveredByHost Boolean            @default(false)
  status          String             @default("AWAITING_PAYMENT")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  host            User               @relation("HostRelation", fields: [hostId], references: [id])
  vendor          Vendor             @relation(fields: [vendorId], references: [id])
  items           OrderItem[]
  participants    ParticipantOrder[]
  deliveryRequest DeliveryRequest?
}

model ParticipantOrder {
  id                   String  @id @default(uuid())
  orderId              String
  userId               String
  shareAmount          Float
  sawaSubsidy          Float   @default(0.0)
  hasPaid              Boolean @default(false)
  paymentScreenshotUrl String?
  ocrVerificationLog   String?
  order                Order   @relation(fields: [orderId], references: [id])
  user                 User    @relation(fields: [userId], references: [id])
}

model OrderItem {
  id           String     @id @default(uuid())
  orderId      String
  menuItemId   String?
  flashDropId  String?
  name         String
  price        Float
  quantity     Int        @default(1)
  modifiers    String
  specialNotes String?
  flashDrop    FlashDrop? @relation(fields: [flashDropId], references: [id])
  menuItem     MenuItem?  @relation(fields: [menuItemId], references: [id])
  order        Order      @relation(fields: [orderId], references: [id])
}

model DeliveryRequest {
  id             String   @id @default(uuid())
  orderId        String   @unique
  requesterId    String
  delivererId    String?
  campusLocation String
  status         String   @default("OPEN") // OPEN | ACCEPTED | DELIVERED | CANCELLED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  order          Order    @relation(fields: [orderId], references: [id])
  requester      User     @relation("DeliveryRequests", fields: [requesterId], references: [id])
  deliverer      User?    @relation("AcceptedDeliveries", fields: [delivererId], references: [id])
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model SafeSession {
  id              String   @id
  hostId          String
  hostName        String
  restaurantId    String
  restaurantName  String
  targetAmount    Int      @default(2)
  timeRemaining   Int      @default(300)
  maxTime         Int      @default(300)
  status          String   @default("ACTIVE")
  isCoveredByHost Boolean  @default(false)
  isGlobal        Boolean  @default(false)
  orderId         String?
  orderNumber     String?
  participants    Json     @default("[]")
  orders          Json     @default("[]")
  deployedCards   Json     @default("[]")
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SystemSnapshot {
  id                String   @id @default(uuid())
  dateString        String   @unique // e.g. "2026-04-03"
  totalRevenue      Float    @default(0.0)
  groupRevenue      Float    @default(0.0)
  soloRevenue       Float    @default(0.0)
  platformTake      Float    @default(0.0)
  totalOrders       Int      @default(0)
  groupOrders       Int      @default(0)
  totalParticipants Int      @default(0)
  activeUsers       Int      @default(0)
  updatedAt         DateTime @updatedAt
}

model UserCohort {
  id        String   @id @default(uuid())
  date      DateTime @unique
  weekLabel String   // e.g. "March W1"
  day1Rate  Float    @default(0.0)
  day7Rate  Float    @default(0.0)
  day30Rate Float    @default(0.0)
  updatedAt DateTime @updatedAt
}
